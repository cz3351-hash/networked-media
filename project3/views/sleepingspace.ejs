            <div class="galleryItem">
                <img src="/images/<%= entry.pillowImage %>" class="galleryPillow">
                <p>
                    <%= entry.guestName %>
                </p>
            </div>
            <% } %>
    </div>

    <br><br><br><br><br>
    <div>
        <a href="/guestbook" class="nopurple enter">take another nap</a>
        <br><br>
        <a href="/" class="nopurple enter">Community manifesto</a>
    </div>

</body>

</html>